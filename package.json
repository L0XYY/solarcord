{
  "name": "solarcord",
  "version": "0.1.0",
  "private": true,
  "description": "SolarCord — modern real-time community chat platform",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c yellow,magenta \"pnpm --filter @solarcord/api dev\" \"pnpm --filter @solarcord/web dev\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @solarcord/db generate",
    "db:migrate": "pnpm --filter @solarcord/db migrate",
    "db:push": "pnpm --filter @solarcord/db push",
    "db:studio": "pnpm --filter @solarcord/db studio",
    "db:seed": "pnpm --filter @solarcord/db seed"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3"
  }
}
