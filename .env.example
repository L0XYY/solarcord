# Copy to .env — these defaults work with the bundled docker-compose.
# ───────────────────────────────────────────────────────────────

# Database (Postgres)
DATABASE_URL="postgresql://solarcord:solarcord@localhost:5432/solarcord?schema=public"

# Redis (presence, pub/sub, rate limits)
REDIS_URL="redis://localhost:6379"

# Auth secrets — REPLACE with long random strings in any real deployment.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="30"

# Server
API_PORT="4000"
API_HOST="0.0.0.0"
WEB_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# Frontend (must be prefixed NEXT_PUBLIC_ to reach the browser)
NEXT_PUBLIC_API_URL="http://localhost:4000"
