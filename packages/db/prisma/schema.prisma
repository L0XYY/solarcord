// SolarCord database schema.
// Phase 1 actively uses: User, RefreshToken, Server, ServerMember, Role, Channel, Message.
// The rest are scaffolded now so migrations stay additive as later phases land.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum PresenceStatus {
  ONLINE
  IDLE
  DND
  INVISIBLE
  OFFLINE
}

enum ChannelType {
  TEXT
  VOICE
  VIDEO
  ANNOUNCEMENT
  STAGE
  FORUM
  MEDIA
  RULES
}

enum ServerVisibility {
  PRIVATE
  PUBLIC
  COMMUNITY
  DISCOVERABLE
}

enum MessageType {
  DEFAULT
  REPLY
  SYSTEM
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum ServerBadgeType {
  COMMUNITY
  DISCOVERABLE
  SOLAR_PARTNER
  VERIFIED
  OFFICIAL_CREATOR
  OFFICIAL_BRAND
  STAFF_PICK
  BOOSTED
  SAFE_COMMUNITY
}

enum BadgeApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

// ─────────────────────────── Users ───────────────────────────

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  username     String         @unique
  displayName  String?
  passwordHash String
  avatarUrl    String?
  bannerUrl    String?
  bio          String?
  pronouns     String?
  status       PresenceStatus @default(OFFLINE)
  customStatus String?
  themePrimary String? // profile theme banner colour (hex)
  themeAccent  String? // profile theme accent colour (hex)
  tag          String? // server tag the user reps next to their name
  tagBadge     String? // the tag's badge icon
  isStaff      Boolean        @default(false)
  isSuspended  Boolean        @default(false)
  isBot        Boolean        @default(false)
  botOwnerId   String? // for bot users: the developer who owns them
  twoFactorSecret String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  settings        UserSettings?
  refreshTokens   RefreshToken[]
  ownedServers    Server[]        @relation("ServerOwner")
  memberships     ServerMember[]
  messages        Message[]
  badges          UserBadgeLink[]
  sentFriends     Friendship[]    @relation("FriendRequester")
  recvFriends     Friendship[]    @relation("FriendAddressee")
  conversations   ConversationParticipant[]
  directMessages  DirectMessage[] @relation("DMAuthor")
  bans            Ban[]           @relation("BannedUser")
  auditEntries    AuditLog[]      @relation("AuditActor")
  reportsMade     Report[]        @relation("Reporter")

  @@index([status])
}

model UserSettings {
  id                String  @id @default(cuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme             String  @default("dark") // "dark" | "light" | "system"
  locale            String  @default("en")
  reducedMotion     Boolean @default(false)
  allowDmsFromGuild Boolean @default(true)
  allowFriendReqs   Boolean @default(true)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  userAgent String?
  ip        String?

  @@index([userId])
}

// Catalog of platform-level user badges (Staff, Early Supporter, Solar+, etc.)
model UserBadge {
  id          String          @id @default(cuid())
  key         String          @unique // e.g. "staff", "early_supporter"
  name        String
  description String
  iconUrl     String?
  holders     UserBadgeLink[]
}

model UserBadgeLink {
  id        String    @id @default(cuid())
  userId    String
  badgeId   String
  grantedAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     UserBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

// ─────────────────────────── Servers ───────────────────────────

model Server {
  id          String           @id @default(cuid())
  name        String
  description String?
  iconUrl     String?
  bannerUrl   String?
  splashUrl   String?
  ownerId     String
  owner       User             @relation("ServerOwner", fields: [ownerId], references: [id])
  visibility  ServerVisibility @default(PRIVATE)
  category    String?
  isVerified  Boolean          @default(false)
  isPartnered Boolean          @default(false)
  boostLevel  Int              @default(0)
  boostCount  Int              @default(0) // number of boosts the server has
  tag         String?          // short server tag (e.g. "5CCU")
  tagBadge    String?          // tag badge icon (data URL or emoji)
  memberCount Int              @default(1)
  vanityUrl   String?          @unique
  bannedWords String[]         @default([]) // AutoMod keyword filter
  isRemoved   Boolean          @default(false) // taken down by platform staff
  rules       String[]         @default([]) // server rules shown on the welcome screen
  welcomeMessage String?       // greeting on the welcome/guide screen
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  members      ServerMember[]
  roles        Role[]
  channels     Channel[]
  invites      Invite[]
  badges       ServerBadge[]
  badgeApps    BadgeApplication[]
  bans         Ban[]
  warnings     Warning[]
  modNotes     ModNote[]
  auditLogs    AuditLog[]

  @@index([visibility])
  @@index([category])
}

model ServerMember {
  id           String    @id @default(cuid())
  serverId     String
  userId       String
  nickname     String?
  timeoutUntil DateTime? // member is muted until this time
  joinedAt     DateTime  @default(now())
  server       Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles        MemberRole[]

  @@unique([serverId, userId])
  @@index([userId])
}

model Ban {
  id         String   @id @default(cuid())
  serverId   String
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  bannedById String
  reason     String?
  createdAt  DateTime @default(now())

  @@unique([serverId, userId])
  @@index([serverId])
}

model Warning {
  id          String   @id @default(cuid())
  serverId    String
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  userId      String // warned member
  moderatorId String
  reason      String
  createdAt   DateTime @default(now())

  @@index([serverId, userId])
}

model ModNote {
  id        String   @id @default(cuid())
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  userId    String // subject of the note
  authorId  String
  content   String
  createdAt DateTime @default(now())

  @@index([serverId, userId])
}

model Role {
  id          String   @id @default(cuid())
  serverId    String
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  name        String
  color       Int      @default(0)
  iconUrl     String?
  position    Int      @default(0)
  // Permission bitfield stored as string (BigInt range). See @solarcord/shared Permission enum.
  permissions String   @default("0")
  isEveryone  Boolean  @default(false)
  isHoisted   Boolean  @default(false)
  mentionable Boolean  @default(false)
  createdAt   DateTime @default(now())

  members   MemberRole[]
  overrides ChannelPermissionOverride[]

  @@index([serverId])
}

model MemberRole {
  id       String       @id @default(cuid())
  memberId String
  roleId   String
  member   ServerMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role     Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([memberId, roleId])
}

// ─────────────────────────── Channels ───────────────────────────

model Channel {
  id         String      @id @default(cuid())
  serverId   String
  server     Server      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  type       ChannelType @default(TEXT)
  name       String
  topic      String?
  position   Int         @default(0)
  parentId   String?     // category grouping (a Channel acting as category)
  isNsfw     Boolean     @default(false)
  slowmodeSeconds Int    @default(0)
  createdAt  DateTime    @default(now())

  messages  Message[]
  overrides ChannelPermissionOverride[]
  webhooks  Webhook[]

  @@index([serverId])
}

// A developer's bot application. The bot itself is a User (isBot=true); the
// token authenticates API requests as that bot user via "Authorization: Bot <token>".
model BotApplication {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String // developer user id
  botUserId   String   @unique
  token       String   @unique
  createdAt   DateTime @default(now())

  @@index([ownerId])
}

model Webhook {
  id          String   @id @default(cuid())
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  serverId    String
  name        String
  avatarUrl   String?
  token       String   @unique
  createdById String
  createdAt   DateTime @default(now())

  @@index([channelId])
}

// Per-channel allow/deny overrides for a role OR a specific member.
model ChannelPermissionOverride {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  roleId    String?
  role      Role?    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  memberId  String?  // for member-specific overrides
  allow     String   @default("0")
  deny      String   @default("0")

  @@index([channelId])
}

// ─────────────────────────── Messages ───────────────────────────

model Message {
  id            String      @id @default(cuid())
  channelId     String
  channel       Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId      String
  author        User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type          MessageType @default(DEFAULT)
  content       String
  replyToId     String?
  replyTo       Message?    @relation("MessageReply", fields: [replyToId], references: [id])
  replies       Message[]   @relation("MessageReply")
  editedAt      DateTime?
  pinned        Boolean     @default(false)
  webhookName   String? // if set, this message was posted by a webhook (display override)
  webhookAvatar String?
  createdAt     DateTime    @default(now())

  attachments MessageAttachment[]
  reactions   Reaction[]

  @@index([channelId, createdAt])
}

model MessageAttachment {
  id        String  @id @default(cuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  filename  String
  mimeType  String
  sizeBytes Int
  width     Int?
  height    Int?
}

model Reaction {
  id        String  @id @default(cuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String  // unicode or custom emoji id
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// ─────────────────────────── Invites ───────────────────────────

model Invite {
  id        String   @id @default(cuid())
  code      String   @unique
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channelId String?
  inviterId String
  maxUses   Int?
  uses      Int      @default(0)
  expiresAt DateTime?
  createdAt DateTime @default(now())

  @@index([serverId])
}

// ─────────────────────────── Friends & DMs ───────────────────────────

model Friendship {
  id          String       @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  requester   User         @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User         @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
}

// ─────────────────────────── DMs & group DMs ───────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  isGroup   Boolean  @default(false)
  name      String? // group name (1:1 derives name from the other participant)
  iconUrl   String?
  ownerId   String? // group creator
  createdAt DateTime @default(now())

  participants ConversationParticipant[]
  messages     DirectMessage[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model DirectMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       String
  author         User           @relation("DMAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content        String
  replyToId      String?
  replyTo        DirectMessage? @relation("DMReply", fields: [replyToId], references: [id])
  replies        DirectMessage[] @relation("DMReply")
  editedAt       DateTime?
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
}

// ─────────────────────────── Server badges & applications ───────────────────────────

model ServerBadge {
  id        String          @id @default(cuid())
  serverId  String
  server    Server          @relation(fields: [serverId], references: [id], onDelete: Cascade)
  type      ServerBadgeType
  grantedAt DateTime        @default(now())

  @@unique([serverId, type])
}

model BadgeApplication {
  id          String                 @id @default(cuid())
  serverId    String
  server      Server                 @relation(fields: [serverId], references: [id], onDelete: Cascade)
  type        ServerBadgeType
  status      BadgeApplicationStatus @default(PENDING)
  reason      String?                // applicant's justification
  reviewNote  String?                // staff note
  reviewerId  String?
  createdAt   DateTime               @default(now())
  reviewedAt  DateTime?

  @@index([status])
}

// ─────────────────────────── Moderation ───────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  serverId   String
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  actorId    String
  actor      User     @relation("AuditActor", fields: [actorId], references: [id])
  action     String   // e.g. "channel.create", "member.kick"
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([serverId, createdAt])
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  reporter    User         @relation("Reporter", fields: [reporterId], references: [id])
  targetType  String       // "message" | "user" | "server"
  targetId    String
  reason      String
  status      ReportStatus @default(OPEN)
  createdAt   DateTime     @default(now())

  @@index([status])
}
